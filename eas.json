{
  "cli": {
    "version": ">= 14.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "ENVIRONMENT": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "ENVIRONMENT": "staging"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "credentialsSource": "local"
      },
      "ios": {
        "credentialsSource": "local"
      },
      "env": {
        "ENVIRONMENT": "production"
      }
    }
  },
  "submit": {}
}
